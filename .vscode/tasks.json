{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch vscode-agent-tasks",
      "type": "shell",
      "command": "nx",
      "args": ["run", "vscode-agent-tasks:dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Watching for changes\\.\\.\\.$",
          "endsPattern": "^Watching for changes\\.\\.\\.$"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Build vscode-agent-tasks",
      "type": "shell",
      "command": "nx",
      "args": ["run", "vscode-agent-tasks:build"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Package vscode-agent-tasks",
      "type": "shell",
      "command": "nx",
      "args": ["run", "vscode-agent-tasks:package"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Test vscode-agent-tasks",
      "type": "shell",
      "command": "nx",
      "args": ["run", "vscode-agent-tasks:test"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
