{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run vscode-agent-tasks Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-agent-tasks"],
      "outFiles": ["${workspaceFolder}/packages/vscode-agent-tasks/dist/**/*.js"],
      "preLaunchTask": "Watch vscode-agent-tasks"
    },
    {
      "name": "Run vscode-agent-tasks Extension (No Watch)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-agent-tasks"],
      "outFiles": ["${workspaceFolder}/packages/vscode-agent-tasks/dist/**/*.js"]
    }
  ]
}
