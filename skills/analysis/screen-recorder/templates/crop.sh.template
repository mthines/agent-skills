#!/usr/bin/env bash
# Generated by the screen-recorder skill.
# Crops the raw Playwright .webm to the target element bounding box,
# then optionally transcodes to .mp4 or .gif.
#
# Inputs (env): DIR, RAW, OUT_FORMAT, PADDING (default 16).

set -euo pipefail

DIR=${DIR:?missing DIR}
RAW=${RAW:?missing RAW}
OUT_FORMAT=${OUT_FORMAT:-webm}
PADDING=${PADDING:-16}
# Max output width (px). Defaults to 768 — the Pareto knee on the video-analyser
# legibility curve. Smaller crops are NOT upscaled; larger crops are downscaled
# proportionally. Set MAX_WIDTH=0 to disable downscaling entirely.
MAX_WIDTH=${MAX_WIDTH:-768}
# Force a keyframe every 0.5 s (15 frames at 30 fps). The video-analyser samples
# I-frames first; a short GOP guarantees its 8-frame default catches the
# interaction's scene transitions even for clips as short as 3 s.
KEYINT=${KEYINT:-15}
SLUG=$(basename "$DIR")

# Validate slug: only alphanumerics, hyphens, underscores.
# A slug with spaces, semicolons, or shell metacharacters would corrupt the
# ffmpeg filter string and output paths.
if [[ ! "$SLUG" =~ ^[A-Za-z0-9_-]+$ ]]; then
  echo "ERROR: invalid slug '$SLUG' — must match [A-Za-z0-9_-]+" >&2
  exit 1
fi

if [[ ! -f "$DIR/bbox.json" ]]; then
  echo "ERROR: $DIR/bbox.json missing" >&2
  exit 1
fi

read x y w h < <(jq -r '"\(.x) \(.y) \(.w) \(.h)"' "$DIR/bbox.json")

# Guard: all four bbox values must be non-empty integers.
for _var in x y w h; do
  _val="${!_var}"
  if [[ -z "$_val" ]] || [[ ! "$_val" =~ ^-?[0-9]+$ ]]; then
    echo "ERROR: bbox.json field '$_var' is not an integer (got '${_val}')" >&2
    exit 1
  fi
done

# Source dimensions and duration — probe the RAW (source) file, not the cropped
# output.  The crop pass may alter container timing (VP9 variable-frame-rate), so
# duration from the cropped file can disagree with the source by a partial GOP.
# Probing the source gives the most accurate duration for the .gif budget check.
read SW SH < <(ffprobe -v error -select_streams v:0 \
  -show_entries stream=width,height -of csv=p=0 "$RAW" | tr ',' ' ')
SOURCE_DURATION_S=$(ffprobe -v error -show_entries format=duration \
  -of csv=p=0 "$RAW" | awk '{print int($1+0.5)}')

# Apply padding and clamp to source dimensions
x2=$(( x - PADDING ));     y2=$(( y - PADDING ))
w2=$(( w + 2*PADDING ));   h2=$(( h + 2*PADDING ))
(( x2 < 0 )) && { w2=$(( w2 + x2 )); x2=0; }
(( y2 < 0 )) && { h2=$(( h2 + y2 )); y2=0; }
(( x2 + w2 > SW )) && w2=$(( SW - x2 ))
(( y2 + h2 > SH )) && h2=$(( SH - y2 ))

if (( w2 <= 0 || h2 <= 0 )); then
  echo "ERROR: degenerate crop after clamp" >&2
  exit 1
fi

CROPPED_WEBM="$DIR/$SLUG.webm"

# Build the filter chain.  Crop first, then downscale to MAX_WIDTH px wide.
# `min(MAX_WIDTH,iw)` clamps to the source width — small crops are never upscaled.
# `:-2` keeps aspect ratio and rounds height to even (required by libvpx-vp9 / libx264).
if (( MAX_WIDTH > 0 )); then
  VF_CHAIN="crop=${w2}:${h2}:${x2}:${y2},scale='min(${MAX_WIDTH},iw)':-2"
else
  VF_CHAIN="crop=${w2}:${h2}:${x2}:${y2}"
fi

ffmpeg -y -i "$RAW" \
  -filter:v "$VF_CHAIN" \
  -c:v libvpx-vp9 -b:v 0 -crf 32 \
  -g "$KEYINT" -keyint_min "$KEYINT" \
  -an \
  "$CROPPED_WEBM" >/dev/null 2>&1

OUT_PATH="$CROPPED_WEBM"

case "$OUT_FORMAT" in
  webm)
    : # already done
    ;;
  mp4)
    OUT_PATH="$DIR/$SLUG.mp4"
    # `-g $KEYINT -keyint_min $KEYINT -sc_threshold 0` forces a fixed-interval GOP
    # so the video-analyser's I-frame sampling extracts evenly-spaced frames.
    ffmpeg -y -i "$CROPPED_WEBM" \
      -c:v libx264 -preset veryfast -crf 23 \
      -pix_fmt yuv420p \
      -movflags +faststart \
      -g "$KEYINT" -keyint_min "$KEYINT" -sc_threshold 0 \
      -an \
      "$OUT_PATH" >/dev/null 2>&1
    ;;
  gif)
    # Budget check: only allow .gif for short, small clips.
    # Use SOURCE_DURATION_S (probed from the raw file above) — the cropped
    # container may report a slightly different duration due to VP9 GOP
    # boundaries, which could flip the check for clips right at the 4 s boundary.
    if (( SOURCE_DURATION_S > 4 || w2 > 400 || h2 > 400 )); then
      echo "ERROR: refusing to transcode to .gif (clip ${SOURCE_DURATION_S}s at ${w2}x${h2})." >&2
      echo "Use .mp4 or trim first." >&2
      exit 1
    fi
    PAL="$DIR/$SLUG-palette.png"
    OUT_PATH="$DIR/$SLUG.gif"
    ffmpeg -y -i "$CROPPED_WEBM" \
      -vf "fps=15,scale=400:-1:flags=lanczos,palettegen=stats_mode=full" \
      "$PAL" >/dev/null 2>&1
    ffmpeg -y -i "$CROPPED_WEBM" -i "$PAL" \
      -filter_complex "fps=15,scale=400:-1:flags=lanczos[x];[x][1:v]paletteuse=dither=bayer:bayer_scale=5" \
      "$OUT_PATH" >/dev/null 2>&1
    ;;
  *)
    echo "ERROR: unknown OUT_FORMAT '$OUT_FORMAT' (expected webm|mp4|gif)" >&2
    exit 1
    ;;
esac

SIZE_KB=$(( $(wc -c < "$OUT_PATH") / 1024 ))

echo "RECORDING_PATH=$OUT_PATH"
echo "RECORDING_FORMAT=$OUT_FORMAT"
echo "RECORDING_SIZE_KB=$SIZE_KB"
echo "CROPPED=yes"
